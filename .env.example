# Local dev: browser calls /api; Vite proxies to VITE_BACKEND_URL (see vite.config.js).
VITE_API_URL=/api
VITE_BACKEND_URL=http://localhost:5000

# Production: set VITE_API_URL to your App Service API base (must include /api).
# Prefer CI/CD variables, or use .env.production (committed for this repo).
# VITE_API_URL=https://your-backend.azurewebsites.net/api
