# Local development — Vite proxies /api → VITE_BACKEND_URL
VITE_API_BASE_URL=/api
VITE_BACKEND_URL=http://localhost:5000

# Production build (Azure Static Web Apps) — full URL to API root on App Service
# VITE_API_BASE_URL=https://your-backend.azurewebsites.net/api

# Legacy alias (optional)
# VITE_API_URL=https://your-backend.azurewebsites.net/api
